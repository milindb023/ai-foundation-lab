# OpenRouter API key for LLM answer generation
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Allowed origins for CORS (separate multiple origins with commas)
ALLOWED_ORIGINS=http://localhost:3000

# Path to serialize FAISS vector databases
FAISS_INDEX_PATH=./faiss_index

# File to log evaluation metrics
EVAL_LOG_PATH=./logs/ragas_eval.jsonl

# Log settings (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO
